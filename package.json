{
  "name": "vietnamese-name-generator",
  "version": "0.1.0",
  "description": "Generate realistic Vietnamese names with gender, region, era, and meaning filtering",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl": "tsx scripts/crawl/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vietnamese",
    "name",
    "generator",
    "faker",
    "vietnam",
    "random"
  ],
  "author": "hungnguyen",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
